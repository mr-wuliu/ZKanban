<Window x:Class="ZhipuUsageWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="智谱用量悬浮组件"
        Width="450"
        Height="274"
        MinWidth="410"
        MinHeight="0"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        ShowInTaskbar="True"
        WindowStartupLocation="Manual"
        Topmost="True">
    <Window.Resources>
    </Window.Resources>

    <Border x:Name="RootBorder" CornerRadius="18" Background="#CC0B1220" BorderBrush="#46DDE7F2" BorderThickness="1" Padding="10" MouseLeftButtonDown="RootBorder_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition x:Name="ContentRow" Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button x:Name="ExpandButton"
                        Grid.Column="0"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Content="展开"
                        Click="CollapseMenuItem_Click"
                        BorderThickness="0"
                        Visibility="Collapsed"
                        Margin="0,0,6,0" />

                <Border x:Name="ModeButtonsBorder" Grid.Column="1" CornerRadius="10" Background="#132234" BorderBrush="#27445C" BorderThickness="1" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="ChartModeButton" Style="{StaticResource ToolbarButtonStyle}" Content="曲线图" Click="ChartModeButton_Click" BorderThickness="0" />
                        <Button x:Name="SummaryModeButton" Style="{StaticResource ToolbarButtonStyle}" Content="概览" Click="SummaryModeButton_Click" BorderThickness="0" />
                    </StackPanel>
                </Border>

                <Button x:Name="CurveSelectorButton"
                        Grid.Column="2"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Width="76"
                        Margin="0,0,6,0"
                        Click="CurveSelectorButton_Click"
                        Content="曲线">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="CurveContextMenu" />
                    </Button.ContextMenu>
                </Button>

                <Border x:Name="RangeButtonsBorder" Grid.Column="3" CornerRadius="10" Background="#132234" BorderBrush="#27445C" BorderThickness="1" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="TodayRangeButton" Style="{StaticResource ToolbarButtonStyle}" Content="今天" Click="TodayRangeButton_Click" BorderThickness="0" />
                        <Button x:Name="WeekRangeButton" Style="{StaticResource ToolbarButtonStyle}" Content="7天" Click="WeekRangeButton_Click" BorderThickness="0" />
                        <Button x:Name="MonthRangeButton" Style="{StaticResource ToolbarButtonStyle}" Content="30天" Click="MonthRangeButton_Click" BorderThickness="0" />
                    </StackPanel>
                </Border>

                <Button x:Name="GearButton"
                        Grid.Column="6"
                        Width="30"
                        Height="30"
                        Click="GearButton_Click"
                        Background="#14304A"
                        Foreground="#F8FAFC"
                        BorderBrush="#33536D"
                        Cursor="Hand">
                    <Path Data="M7,8 h16 M7,15 h16 M7,22 h16" Stroke="#F8FAFC" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Width="16" Height="16" Stretch="Uniform" />
                    <Button.ContextMenu>
                        <ContextMenu x:Name="GearContextMenu">
                            <MenuItem Header="视图">
                                <MenuItem Header="曲线图" Click="ChartModeMenuItem_Click" />
                                <MenuItem Header="概览" Click="SummaryModeMenuItem_Click" />
                            </MenuItem>
                            <MenuItem Header="设置">
                                <MenuItem Header="账号与登录" Click="OpenSettingsMenuItem_Click" />
                                <MenuItem Header="立即刷新" Click="RefreshMenuItem_Click" />
                                <MenuItem Header="收起 / 展开" Click="CollapseMenuItem_Click" />
                            </MenuItem>
                            <Separator Style="{StaticResource DarkSeparatorStyle}" />
                            <MenuItem Header="关闭组件" Click="CloseMenuItem_Click" />
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </Grid>

            <Grid Grid.Row="1">
                <Grid x:Name="ChartPanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel x:Name="LegendDockPanel" Grid.Row="0" Margin="4,4,0,4" Visibility="Collapsed">
                        <StackPanel x:Name="LegendPanel" Orientation="Horizontal" />
                        <TextBlock x:Name="ChartValueTextBlock"
                                   DockPanel.Dock="Right"
                                   HorizontalAlignment="Right"
                                   Foreground="#F8FAFC"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                    </DockPanel>

                    <Border Grid.Row="1" CornerRadius="14" Background="#A6111827" BorderBrush="#22374D" BorderThickness="1" Padding="4,4,4,4">
                        <Canvas x:Name="ChartCanvas" Height="146" Background="Transparent" ClipToBounds="False"
                                MouseMove="ChartCanvas_MouseMove" MouseLeave="ChartCanvas_MouseLeave">
                            <ItemsControl x:Name="GridLinesItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Canvas>
                                            <Line X1="34" X2="404" Y1="{Binding Top}" Y2="{Binding Top}" Stroke="#243244" StrokeThickness="1" />
                                            <TextBlock Canvas.Left="0" Canvas.Top="{Binding Top}" Text="{Binding Label}" Foreground="#7C8CA5" FontSize="9" />
                                        </Canvas>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ItemsControl x:Name="SeriesItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Path Data="{Binding SmoothPath}" Stroke="{Binding Stroke}" StrokeThickness="2.2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Line x:Name="TrackVerticalLine" X1="0" X2="0" Y1="4" Y2="124" Stroke="#33536D" StrokeThickness="1" StrokeDashArray="3,3" Visibility="Collapsed" />
                            <ItemsControl x:Name="TrackDotsItemsControl" Visibility="Collapsed">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                        <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Ellipse Width="7" Height="7" Stroke="{Binding Stroke}" StrokeThickness="2" Fill="#0F1A2A" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Border x:Name="TrackToolTip" Visibility="Collapsed" CornerRadius="6" Background="#1A2744" BorderBrush="#33536D" BorderThickness="1" Padding="8,5">
                                <StackPanel>
                                    <TextBlock x:Name="TrackTimeText" Foreground="#94A3B8" FontSize="9" Margin="0,0,0,3" />
                                    <ItemsControl x:Name="TrackSeriesItemsControl" FontSize="10">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,1">
                                                    <Ellipse Width="6" Height="6" Fill="{Binding Stroke}" Margin="0,0,5,0" VerticalAlignment="Center" />
                                                    <TextBlock Foreground="#E2E8F0" Text="{Binding Text}" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                            <ItemsControl x:Name="AxisLabelsItemsControl" Canvas.Left="0" Canvas.Top="128">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Height="18" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Text}" Foreground="#7C8CA5" FontSize="9" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Canvas>
                    </Border>
                </Grid>

                <Border x:Name="SummaryPanel" Visibility="Collapsed" CornerRadius="14" Background="#A6111827" BorderBrush="#22374D" BorderThickness="1" Padding="6">
                    <ItemsControl x:Name="SummaryItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="90" Margin="0,0,6,6" Padding="7" CornerRadius="8" Background="#17212E" BorderBrush="#263548" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" Foreground="#94A3B8" FontSize="9" TextWrapping="Wrap" />
                                        <TextBlock Margin="0,2,0,0" Text="{Binding Value}" Foreground="#F8FAFC" FontSize="13" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <TextBlock x:Name="CollapsedHintTextBlock"
                           Visibility="Collapsed"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Foreground="#94A3B8"
                           FontSize="11" />
            </Grid>

            <wv2:WebView2 x:Name="HiddenWebView" Grid.Row="1" Width="0" Height="0" Visibility="Hidden" HorizontalAlignment="Left" VerticalAlignment="Top" />
        </Grid>
    </Border>
</Window>
